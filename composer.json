{
    "name": "sqrart/qart",
    "description": "Artistic QR codes: the image is encoded into the QR data and Reed-Solomon bits (QArt approach), rendered as a color halftone. Fixed QR version 10, ECC L.",
    "type": "library",
    "license": "MIT",
    "keywords": ["qrcode", "qart", "halftone", "art"],
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "chillerlan/php-qrcode": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "SqrArt\\QArt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SqrArt\\QArt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
